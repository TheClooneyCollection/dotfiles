{
  "permissions": {
    "allow": [
      "Bash(ls -la:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Read"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "theme": "dark-ansi",
  "voiceEnabled": true,
  "model": "opus"
}
