{
  "permissions": {
    "allow": [
      "Bash(ls -la:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Read"
    ]
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "voiceEnabled": true
}
